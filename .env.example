# Autonomous Subscription Manager - Environment Configuration
# Copy this file to .env.local and fill in your values

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL Connection String (or MySQL)
# Format: postgresql://user:password@host:port/database
# Example: postgresql://admin:password123@db.example.com:5432/subscriptions
DATABASE_URL=postgresql://user:password@localhost:5432/autonomous_subscription_manager

# Database connection pool settings
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ============================================================================
# AUTHENTICATION
# ============================================================================

# JWT secret key (use a strong, random key in production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# JWT token expiry (e.g., 7d, 24h, 1w)
JWT_EXPIRY=7d

# ============================================================================
# APPLICATION
# ============================================================================

# Node environment
NODE_ENV=development

# Application URL
NEXT_PUBLIC_API_URL=http://localhost:3000

# Application port
PORT=3000

# ============================================================================
# PAYMENT GATEWAY CONFIGURATION
# ============================================================================

# Stripe
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_xxxxx
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# PayPal
PAYPAL_CLIENT_ID=your-client-id
PAYPAL_CLIENT_SECRET=your-client-secret
PAYPAL_MODE=sandbox

# ============================================================================
# EMAIL CONFIGURATION (for notifications)
# ============================================================================

# SMTP settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# SendGrid (alternative)
SENDGRID_API_KEY=SG.xxxxx

# Notification email addresses
ADMIN_EMAIL=admin@example.com
SUPPORT_EMAIL=support@example.com

# ============================================================================
# WEBHOOK CONFIGURATION
# ============================================================================

# Webhook retry settings
WEBHOOK_MAX_RETRIES=5
WEBHOOK_RETRY_DELAY_MS=1000
WEBHOOK_TIMEOUT_MS=30000

# Webhook URLs (for sending events to external services)
WEBHOOK_ENDPOINT=https://your-domain.com/webhooks

# ============================================================================
# LOGGING & MONITORING
# ============================================================================

# Log level: error, warn, info, debug
LOG_LEVEL=info

# Enable database query logging
DATABASE_QUERY_LOG=false

# Sentry (error tracking)
SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# ============================================================================
# RATE LIMITING
# ============================================================================

# Rate limit: requests per minute
RATE_LIMIT_PER_MINUTE=60

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable trial subscriptions
ENABLE_TRIALS=true

# Default trial duration (days)
DEFAULT_TRIAL_DAYS=30

# ============================================================================
# CORS & SECURITY
# ============================================================================

# Allowed origins for CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://yourdomain.com

# CORS credentials
CORS_CREDENTIALS=true
